{
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "channels": {
    "slack": {
      "enabled": true,
      "allowBots": "mentions",
      "groupPolicy": "open",
      "capabilities": {
        "interactiveReplies": true
      },
      "channels": {
        "*": {
          "users": [
            "slack:${HERMES_BOT_USER_ID}",
            "slack:${HUMAN_SLACK_USER_ID}"
          ]
        }
      },
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}"
    }
  },
  "agents": {
    "defaults": {
      "models": {
        "eastrouter/z-ai/glm-5.1": {},
        "eastrouter/moonshotai/kimi-k2.7-code": {},
        "eastrouter/z-ai/glm-4.5-air": {}
      },
      "model": {
        "primary": "eastrouter/moonshotai/kimi-k2.7-code",
        "fallbacks": [
          "eastrouter/z-ai/glm-5.1",
          "eastrouter/z-ai/glm-4.5-air"
        ]
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "eastrouter": {
        "baseUrl": "https://api.eastrouter.com/v1",
        "apiKey": "${EASTROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "moonshotai/kimi-k2.7-code",
            "name": "Kimi K2.7 Code (EastRouter)",
            "contextWindow": 262000,
            "compat": { "supportsTools": true }
          },
          {
            "id": "z-ai/glm-5.1",
            "name": "GLM 5.1 (EastRouter)",
            "contextWindow": 200000,
            "compat": { "supportsTools": true }
          },
          {
            "id": "z-ai/glm-4.5-air",
            "name": "GLM 4.5 Air — fast edits (EastRouter)",
            "contextWindow": 128000,
            "compat": { "supportsTools": true }
          }
        ]
      }
    }
  },
  "plugins": {
    "entries": {
      "slack": { "enabled": true }
    },
    "allow": ["slack", "memory-core"]
  },
  "_note": "All secrets replaced with ${ENV_VAR} placeholders. Primary model: moonshotai/kimi-k2.7-code via EastRouter. Slack channels: #agent-coder (tasks), #agent-log (reports), #sprint-main, #ci-cd, #human-review."
}
